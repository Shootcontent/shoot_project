# ─────────────────────────────────────────────────────────────────────────────
# SHOOT. Studios — Environment Variables
# Add all of these in Vercel → Project Settings → Environment Variables.
# NEVER commit real keys to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Yoco Payment Gateway ──────────────────────────────────────────────────────
# https://portal.yoco.com → Developers → API Keys
# Use TEST keys now; swap to LIVE keys when going to production.
#
# The PUBLIC key is fetched by the frontend via /api/get-config — it is safe
# to expose but should still live in env vars, not hardcoded.
# The SECRET key is ONLY used server-side in /api/create-booking.js and is
# NEVER returned to the browser under any circumstances.
YOCO_PUBLIC_KEY=pk_test_41ce75bf0qNPmJrabf34
YOCO_SECRET_KEY=sk_test_8a1e5043OgMv3R5f6a14b889a644

# ── Vercel KV (Redis) — Booking Database ─────────────────────────────────────
# Enable in Vercel dashboard: Storage → KV → Create Store → Connect to project.
# Vercel injects KV_REST_API_URL and KV_REST_API_TOKEN automatically.
# You only need to add them manually if running locally.
KV_REST_API_URL=https://your-store.upstash.io
KV_REST_API_TOKEN=your_kv_rest_api_token_here

# ── Brevo (Email / Newsletter) ────────────────────────────────────────────────
# https://app.brevo.com → Account → SMTP & API → API Keys
BREVO_API_KEY=your_brevo_api_key_here

# Brevo list ID for newsletter subscribers
BREVO_LIST_ID=2

# Brevo list ID for contacts who have redeemed the SHOOT10 discount
BREVO_REDEEMED_LIST_ID=3

# Verified sender address (must be verified in Brevo → Senders & IP → Senders)
FROM_EMAIL=hello@shootstudios.co.za
