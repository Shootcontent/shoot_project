# Brevo (https://app.brevo.com) — add these in Vercel → Settings → Environment Variables

# Your Brevo API key (Settings → SMTP & API → API Keys)
BREVO_API_KEY=your_brevo_api_key_here

# Brevo List ID for newsletter subscribers
# Create via Brevo → Contacts → Lists → Create a list — note the numeric ID in the URL
BREVO_LIST_ID=2

# Brevo List ID for contacts who have redeemed SHOOT10
# Create a second list called "Discount Redeemed" — note its numeric ID
BREVO_REDEEMED_LIST_ID=3

# Verified sender address (must be verified in Brevo → Senders & IP → Senders)
FROM_EMAIL=hello@shootstudios.co.za
