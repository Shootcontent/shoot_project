# ─────────────────────────────────────────────────────────────
# SHOOT. Studios — Environment Variables
# Copy this file to .env.local for local dev, then add each
# variable to your Vercel project settings for production.
# NEVER commit .env or .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Yoco Payments ──────────────────────────────────────────────
# Get from: https://dashboard.yoco.com/developers
# Test keys start with pk_test_ / sk_test_
YOCO_PUBLIC_KEY=pk_test_c5f8ff1dWk3zMPw0f4c4
YOCO_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_SECRET_KEY
# Set this after adding webhook in Yoco dashboard:
YOCO_WEBHOOK_SECRET=whsec_REPLACE_WITH_WEBHOOK_SECRET

# ── Supabase ───────────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon_key_here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service_role_key_here

# ── Site URL ───────────────────────────────────────────────────
# Used for Yoco redirect URLs — no trailing slash
SITE_URL=https://www.shootstudios.co.za
